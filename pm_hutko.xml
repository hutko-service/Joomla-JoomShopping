<?xml version="1.0" encoding="utf-8"?>
<extension type="file" method="upgrade" version="4.0">
    <name>hutko for JoomShopping</name>
    <element>pm_hutko</element>
    <author>Hutko Service</author>
    <authorEmail>support@hutko.service</authorEmail>
    <authorUrl>https://github.com/hutko-service/Joomla-JoomShopping</authorUrl>
    <version>1.0.1</version>
    <creationDate>2026-04-14</creationDate>
    <copyright>(C) 2026 Hutko Service. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <description>hutko payment method for JoomShopping on Joomla.</description>
    <scriptfile>script.php</scriptfile>

    <files>
        <filename>script.php</filename>
        <filename>README.md</filename>
        <filename>LICENSE.txt</filename>
        <filename>update.xml</filename>
        <filename>update.sql</filename>
        <filename>uninstall.sql</filename>
        <folder>components</folder>
    </files>

    <install>
        <sql>
            <file driver="mysql" charset="utf8mb4">update.sql</file>
        </sql>
    </install>

    <uninstall>
        <sql>
            <file driver="mysql" charset="utf8mb4">uninstall.sql</file>
        </sql>
    </uninstall>

    <updateservers>
        <server type="extension" priority="1" name="hutko for JoomShopping Updates">https://raw.githubusercontent.com/hutko-service/Joomla-JoomShopping/main/update.xml</server>
    </updateservers>
</extension>
